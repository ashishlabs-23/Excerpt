{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Editorial Knowledge Graph",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["archetype", "reaction", "context", "time_factor"] },
          "description": { "type": "string" }
        },
        "required": ["id", "type"]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["source", "target", "weight"]
      }
    }
  },
  "required": ["nodes", "edges"]
}
